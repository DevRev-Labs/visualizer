{
  "title": "DevRev Deployment Framework",
  "subtitle": "Interactive Architecture Visualizer — Pulumi YAML Runtime",
  "tabs": [
    {
      "id": "urn",
      "label": "URN Topology",
      "icon": "box",
      "type": "cards",
      "preview": {
        "label": "Resulting URN",
        "value": "urn:pulumi:acme_software_aws_uswest2_prod::support::devrev:index:WorkflowStep::billing_escalation-step"
      },
      "footer": "Click any card to expand the segment breakdown",
      "items": [
        {
          "id": "stack",
          "label": "Stack Name",
          "colorScheme": "purple",
          "description": "Defines deployment target & isolates tenant state",
          "example": "acme_software_aws_uswest2_prod",
          "segments": [
            { "label": "company", "value": "acme", "desc": "Customer / tenant identifier" },
            { "label": "org", "value": "software", "desc": "Org unit within the company" },
            { "label": "cloud", "value": "aws", "desc": "Cloud provider" },
            { "label": "region", "value": "uswest2", "desc": "Deployment region" },
            { "label": "env", "value": "prod", "desc": "Environment tier" }
          ]
        },
        {
          "id": "project",
          "label": "Project Name",
          "colorScheme": "blue",
          "description": "Domain partitioning — creates micro-stacks for safe concurrent deploys",
          "example": "support",
          "segments": [
            { "label": "domain", "value": "support", "desc": "DevRev product domain (e.g. core, support)" }
          ]
        },
        {
          "id": "type",
          "label": "Resource Type",
          "colorScheme": "green",
          "description": "Pulumi provider, module, and resource class",
          "example": "devrev:index:WorkflowStep",
          "segments": [
            { "label": "provider", "value": "devrev", "desc": "Pulumi provider name" },
            { "label": "module", "value": "index", "desc": "Module within the provider" },
            { "label": "class", "value": "WorkflowStep", "desc": "Resource class" }
          ]
        },
        {
          "id": "logical",
          "label": "Logical Name",
          "colorScheme": "orange",
          "description": "Prevents naming collisions within the same YAML file",
          "example": "billing_escalation-step",
          "segments": [
            { "label": "namespace", "value": "billing", "desc": "Feature namespace" },
            { "label": "identifier", "value": "escalation-step", "desc": "Unique resource identifier" }
          ]
        }
      ]
    },
    {
      "id": "cicd",
      "label": "CI/CD & State",
      "icon": "git-branch",
      "type": "pipeline",
      "footer": "Click a branch to see its matrix deployment and state management",
      "stages": [
        {
          "branch": "main",
          "env": "Dev",
          "gate": "Auto on merge",
          "colorScheme": "green",
          "stacks": ["acme-aws-apne1-dev", "globex-gcp-euw1-dev"]
        },
        {
          "branch": "qa",
          "env": "QA",
          "gate": "QA Team Approval",
          "colorScheme": "yellow",
          "stacks": ["acme-aws-apne1-qa", "globex-gcp-euw1-qa"]
        },
        {
          "branch": "prod",
          "env": "Prod",
          "gate": "Eng Lead Approval",
          "colorScheme": "red",
          "stacks": ["acme-aws-apne1-prod", "globex-gcp-euw1-prod", "<tenant>-<cloud>-prod"]
        }
      ],
      "backends": [
        {
          "icon": "database",
          "title": "DynamoDB",
          "subtitle": "State Locking",
          "colorScheme": "yellow",
          "description": "First `pulumi up` acquires lock on stack. Concurrent runs receive an error until lock is released."
        },
        {
          "icon": "cloud",
          "title": "S3",
          "subtitle": "State Storage",
          "colorScheme": "blue",
          "description": "`.pulumi/stacks/<project>/<stack>.json` — one JSON file per tenant, zero cross-tenant overlap."
        }
      ]
    },
    {
      "id": "microstacks",
      "label": "Micro-Stacks",
      "icon": "layers",
      "type": "hierarchy",
      "description": "Large DevOrg configurations are split into domain-specific Pulumi Projects to prevent state-file locking during concurrent deployments.",
      "note": "Each stack has its own DynamoDB lock — concurrent deploys across projects never block each other.",
      "domains": [
        {
          "name": "core",
          "stacks": ["acme_software_aws_uswest2_dev", "acme_software_aws_uswest2_prod"]
        },
        {
          "name": "support",
          "stacks": ["acme_software_aws_uswest2_dev", "acme_software_aws_uswest2_prod"]
        }
      ]
    }
  ]
}
